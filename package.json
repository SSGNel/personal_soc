{
  "name": "threat-guard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter desktop-ui dev",
    "dev:backend": "cargo run --manifest-path apps/tauri-shell/src-tauri/Cargo.toml --bin dev_backend",
    "dev:all": "node ./scripts/dev-runner.js",
    "build": "pnpm --filter desktop-ui build",
    "tauri": "cd apps/tauri-shell/src-tauri && cargo tauri dev",
    "tauri:build": "cd apps/tauri-shell/src-tauri && cargo tauri build",
    "lint": "pnpm --filter desktop-ui lint",
    "typecheck": "pnpm --filter desktop-ui typecheck"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "dependencies": {
    "cargo": "^0.8.0"
  }
}
